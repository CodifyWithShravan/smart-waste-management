# ============================================================
#  Smart Waste Management — Root .gitignore
# ============================================================

# --- OS Files ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- IDE / Editor ---
.vscode/
.idea/
*.code-workspace

# --- Node.js (backend & frontend) ---
node_modules/
dist/
dist-ssr/
*.local

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*

# --- Environment / Secrets ---
.env
.env.local
.env.*.local

# --- Python (gateway) ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# --- PlatformIO (hardware firmware) ---
.pio/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# --- Build artifacts ---
build/
*.o
*.obj
*.elf
*.bin
*.hex
